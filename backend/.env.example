# Optional, improves GitHub rate limits and enables private repo reads when the token has access.
GITHUB_TOKEN=

# Optional, enables LLM-written analysis in /api/scan when includeLlm is true.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional server settings.
PORT=8787
ALLOWED_ORIGIN=*

# Public frontend can use this after deployment by setting docs/assets/config.js.
# Example: https://upgrade-copilot-backend.onrender.com
